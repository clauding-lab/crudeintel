# ─── Supabase ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only — NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Data Source API Keys ───────────────────────────────────
# Twelve Data (https://twelvedata.com) — commodity prices
TWELVE_DATA_API_KEY=your-twelve-data-key

# EIA (https://www.eia.gov/opendata/) — US energy fundamentals
EIA_API_KEY=your-eia-key

# NewsAPI (https://newsapi.org) — energy news
NEWS_API_KEY=your-newsapi-key

# Anthropic Claude (https://console.anthropic.com) — AI summaries & briefs
ANTHROPIC_API_KEY=your-anthropic-key
