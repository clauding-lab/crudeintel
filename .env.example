# ─── Supabase ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only — NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Data Source Config ────────────────────────────────────
# Set to "true" to scrape Urals price from Trading Economics
# Only works from residential IPs (local machine), not GitHub Actions
# USE_TE_URALS=true

# EIA (https://www.eia.gov/opendata/) — US energy fundamentals
EIA_API_KEY=your-eia-key

# NewsAPI (https://newsapi.org) — energy news (optional)
# NEWS_API_KEY=your-newsapi-key

# Anthropic Claude (https://console.anthropic.com) — AI summaries & briefs
ANTHROPIC_API_KEY=your-anthropic-key
